{% comment %}
  Esquina Latina Market — collection page with country + category filters
{% endcomment %}

{%- assign country_data = 'brazil|br|Brasil,colombia|co|Colombia,el-salvador|sv|El Salvador,costa-rica|cr|Costa Rica,guatemala|gt|Guatemala,honduras|hn|Honduras,peru|pe|Peru,nicaragua|ni|Nicaragua' | split: ',' -%}

{%- assign category_icons = 'Coffee|☕,Juice|🧃,Soda|🥤,Sauce|🫙,Seasoning|🌶️,Cookies|🍪,Snacks|🍿,Soups|🍲,Baking|🎂,Flours & Starches|🌾,Grains|🌽,Nail Polish|💅,Limpeza Doméstica|🧹,Achocolatados em Pó|🍫,Rice Drinks|🥛' | split: ',' -%}

{%- assign all_tags = collection.all_tags | sort -%}

<div class="shop-layout">

  <!-- Sidebar -->
  <aside class="shop-sidebar">
    <div class="sidebar-sticky">

      <!-- Toggle Countries / Categories -->
      <div class="sidebar-toggle">
        <button class="toggle-btn toggle-btn--active" id="toggleCategories">🏷️ Categorias</button>
        <button class="toggle-btn" id="toggleCountries">🌎 Países</button>
      </div>

      <!-- Categories Panel -->
      <div class="sidebar-panel" id="panelCategories">
        <div class="sidebar-list">
          <button class="sidebar-item sidebar-item--active" data-tag="all">
            📦 <span>Todos</span>
            <span class="sidebar-count">{{ collection.products_count }}</span>
          </button>
          {% for tag in all_tags %}
            {%- assign icon = '🏷️' -%}
            {% for cat_entry in category_icons %}
              {%- assign cat_parts = cat_entry | split: '|' -%}
              {% if cat_parts[0] == tag %}
                {%- assign icon = cat_parts[1] -%}
              {% endif %}
            {% endfor %}
            <button class="sidebar-item" data-tag="{{ tag | escape }}">
              {{ icon }} <span>{{ tag }}</span>
            </button>
          {% endfor %}
        </div>
      </div>

      <!-- Countries Panel -->
      <div class="sidebar-panel sidebar-panel--hidden" id="panelCountries">
        <div class="sidebar-list">
          <a href="/collections/all" class="sidebar-item {% if collection.handle == 'all' %}sidebar-item--active{% endif %}">
            🌎 <span>Todos os países</span>
          </a>
          {% for entry in country_data %}
            {%- assign parts = entry | split: '|' -%}
            {%- assign handle = parts[0] -%}
            {%- assign code = parts[1] -%}
            {%- assign name = parts[2] -%}
            {%- assign col = collections[handle] -%}
            {% if col.products_count > 0 %}
              <a href="{{ col.url }}" class="sidebar-item {% if collection.handle == handle %}sidebar-item--active{% endif %}">
                <img src="https://flagcdn.com/w40/{{ code }}.png" alt="{{ name }}" class="sidebar-flag">
                <span>{{ name }}</span>
                <span class="sidebar-count">{{ col.products_count }}</span>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>

    </div>
  </aside>

  <!-- Main Content -->
  <main class="shop-main">

    <!-- Top Bar -->
    <div class="shop-topbar">
      <div class="shop-search-wrap">
        <span class="shop-search-icon">🔍</span>
        <input type="text" id="shopSearch" class="shop-search" placeholder="Buscar produtos...">
      </div>
      <span class="shop-count" id="productCount">{{ collection.products_count }} produto{% if collection.products_count != 1 %}s{% endif %}</span>
    </div>

    <!-- Mobile Category Pills -->
    <div class="mobile-pills" id="mobilePills">
      <button class="pill pill--active" data-tag="all">Todos</button>
      {% for tag in all_tags %}
        {%- assign icon = '🏷️' -%}
        {% for cat_entry in category_icons %}
          {%- assign cat_parts = cat_entry | split: '|' -%}
          {% if cat_parts[0] == tag %}
            {%- assign icon = cat_parts[1] -%}
          {% endif %}
        {% endfor %}
        <button class="pill" data-tag="{{ tag | escape }}">{{ icon }} {{ tag }}</button>
      {% endfor %}
    </div>

    <!-- Product Grid -->
    <div class="product-grid" id="productGrid">
      {% paginate collection.products by 48 %}
        {% for product in collection.products %}
          {%- assign vendor_lower = product.vendor | downcase -%}
          {%- assign flag_code = '' -%}
          {% for entry in country_data %}
            {%- assign parts = entry | split: '|' -%}
            {%- assign country_name_lower = parts[2] | downcase -%}
            {%- assign country_handle = parts[0] -%}
            {% if vendor_lower == country_name_lower or vendor_lower == country_handle %}
              {%- assign flag_code = parts[1] -%}
            {% endif %}
          {% endfor %}

          <div class="product-card" data-tags="{{ product.tags | join: ',' | escape }}" data-title="{{ product.title | downcase | escape }}">
            <a href="{{ product.url }}" class="product-card__link">
              <div class="product-card__image-wrap">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    class="product-card__image"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {% else %}
                  <div class="product-card__no-image">📦</div>
                {% endif %}

                {% unless product.available %}
                  <div class="product-card__sold-out">Esgotado</div>
                {% endunless %}

                {% if flag_code != '' %}
                  <img src="https://flagcdn.com/w40/{{ flag_code }}.png" alt="" class="product-card__flag" loading="lazy">
                {% endif %}
              </div>

              <div class="product-card__info">
                <h3 class="product-card__title">{{ product.title | escape }}</h3>
                <div class="product-card__price-row">
                  {% if product.compare_at_price > product.price %}
                    <span class="product-card__compare">${{ product.compare_at_price | money_without_currency }}</span>
                  {% endif %}
                  <span class="product-card__price">{{ product.price | money }}</span>
                </div>
              </div>
            </a>
            <div class="product-card__actions">
              {% form 'product', product %}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button type="submit" class="add-to-cart-btn" {% unless product.available %}disabled{% endunless %}>
                  🛒 {% if product.available %}Adicionar{% else %}Esgotado{% endif %}
                </button>
              {% endform %}
            </div>
          </div>
        {% endfor %}

        {% if paginate.pages > 1 %}
          <div class="pagination">{{ paginate | default_pagination }}</div>
        {% endif %}
      {% endpaginate %}
    </div>

    <div class="shop-empty" id="shopEmpty" style="display:none">
      <p>📦</p>
      <p>Nenhum produto encontrado.</p>
    </div>

  </main>
</div>

<script>
(function () {
  var activeTag = 'all';
  var searchVal = '';

  var cards = Array.from(document.querySelectorAll('.product-card'));
  var countEl = document.getElementById('productCount');
  var emptyEl = document.getElementById('shopEmpty');
  var searchEl = document.getElementById('shopSearch');

  function filter() {
    var visible = 0;
    cards.forEach(function (card) {
      var tags = (card.dataset.tags || '').split(',').map(function(t){ return t.trim(); });
      var title = card.dataset.title || '';
      var tagMatch = activeTag === 'all' || tags.includes(activeTag);
      var searchMatch = !searchVal || title.includes(searchVal);
      var show = tagMatch && searchMatch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (countEl) countEl.textContent = visible + (visible === 1 ? ' produto' : ' produtos');
    if (emptyEl) emptyEl.style.display = visible === 0 ? '' : 'none';
  }

  // Sidebar category buttons
  document.querySelectorAll('.sidebar-item[data-tag]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      activeTag = btn.dataset.tag;
      document.querySelectorAll('.sidebar-item[data-tag]').forEach(function (b) { b.classList.remove('sidebar-item--active'); });
      btn.classList.add('sidebar-item--active');
      // Sync pills
      document.querySelectorAll('.pill').forEach(function (p) {
        p.classList.toggle('pill--active', p.dataset.tag === activeTag);
      });
      filter();
    });
  });

  // Mobile pills
  document.querySelectorAll('.pill').forEach(function (pill) {
    pill.addEventListener('click', function () {
      activeTag = pill.dataset.tag;
      document.querySelectorAll('.pill').forEach(function (p) { p.classList.remove('pill--active'); });
      pill.classList.add('pill--active');
      // Sync sidebar
      document.querySelectorAll('.sidebar-item[data-tag]').forEach(function (b) {
        b.classList.toggle('sidebar-item--active', b.dataset.tag === activeTag);
      });
      filter();
    });
  });

  // Search
  if (searchEl) {
    searchEl.addEventListener('input', function () {
      searchVal = searchEl.value.toLowerCase().trim();
      filter();
    });
  }

  // Toggle sidebar panels
  var btnCat = document.getElementById('toggleCategories');
  var btnCou = document.getElementById('toggleCountries');
  var panelCat = document.getElementById('panelCategories');
  var panelCou = document.getElementById('panelCountries');

  if (btnCat && btnCou) {
    btnCat.addEventListener('click', function () {
      btnCat.classList.add('toggle-btn--active');
      btnCou.classList.remove('toggle-btn--active');
      panelCat.classList.remove('sidebar-panel--hidden');
      panelCou.classList.add('sidebar-panel--hidden');
    });
    btnCou.addEventListener('click', function () {
      btnCou.classList.add('toggle-btn--active');
      btnCat.classList.remove('toggle-btn--active');
      panelCou.classList.remove('sidebar-panel--hidden');
      panelCat.classList.add('sidebar-panel--hidden');
    });
  }
})();
</script>

{% stylesheet %}
  /* Layout */
  .shop-layout {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 0;
    align-items: flex-start;
  }

  /* Sidebar */
  .shop-sidebar {
    width: 200px;
    flex-shrink: 0;
    display: none;
  }
  @media (min-width: 768px) {
    .shop-sidebar { display: block; }
  }
  .sidebar-sticky {
    position: sticky;
    top: 5.5rem;
  }

  /* Toggle */
  .sidebar-toggle {
    display: flex;
    background: var(--color-border);
    border-radius: var(--radius-sm);
    padding: 3px;
    gap: 3px;
    margin-bottom: 0.75rem;
  }
  .toggle-btn {
    flex: 1;
    padding: 0.35rem 0.5rem;
    border-radius: 4px;
    border: none;
    background: transparent;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--color-muted);
    transition: all 0.15s;
  }
  .toggle-btn--active {
    background: var(--color-card);
    color: var(--color-foreground);
    box-shadow: var(--shadow-sm);
  }

  /* Panels */
  .sidebar-panel--hidden { display: none; }

  /* Sidebar list */
  .sidebar-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-card);
    padding: 6px;
  }
  .sidebar-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.6rem;
    border-radius: var(--radius-sm);
    border: none;
    background: transparent;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-muted);
    cursor: pointer;
    text-decoration: none;
    text-align: left;
    transition: background 0.12s, color 0.12s;
    width: 100%;
  }
  .sidebar-item:hover {
    background: var(--color-background);
    color: var(--color-foreground);
  }
  .sidebar-item--active {
    background: var(--color-foreground);
    color: #fff;
    font-weight: 600;
  }
  .sidebar-count {
    margin-left: auto;
    font-size: 0.7rem;
    color: var(--color-muted);
  }
  .sidebar-item--active .sidebar-count { color: rgba(255,255,255,0.6); }
  .sidebar-flag {
    width: 24px;
    height: 16px;
    object-fit: cover;
    border-radius: 3px;
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }

  /* Main */
  .shop-main { flex: 1; min-width: 0; }

  /* Top bar */
  .shop-topbar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .shop-search-wrap {
    position: relative;
    flex: 1;
  }
  .shop-search-icon {
    position: absolute;
    left: 0.7rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.9rem;
    pointer-events: none;
  }
  .shop-search {
    width: 100%;
    padding: 0.5rem 0.75rem 0.5rem 2.2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    background: var(--color-card);
    outline: none;
    transition: border-color 0.15s;
  }
  .shop-search:focus { border-color: var(--color-foreground); }
  .shop-count {
    font-size: 0.82rem;
    color: var(--color-muted);
    white-space: nowrap;
  }

  /* Mobile pills */
  .mobile-pills {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.75rem;
    scrollbar-width: none;
  }
  .mobile-pills::-webkit-scrollbar { display: none; }
  @media (min-width: 768px) { .mobile-pills { display: none; } }
  .pill {
    padding: 0.3rem 0.8rem;
    border-radius: 2rem;
    border: 1px solid var(--color-border);
    background: var(--color-card);
    font-size: 0.78rem;
    font-weight: 500;
    white-space: nowrap;
    cursor: pointer;
    color: var(--color-muted);
    transition: all 0.12s;
  }
  .pill--active {
    background: var(--color-foreground);
    border-color: var(--color-foreground);
    color: #fff;
  }

  /* Product Grid */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 1rem;
  }
  @media (min-width: 1024px) {
    .product-grid { grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); }
  }

  /* Product Card */
  .product-card {
    background: var(--color-card);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .product-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .product-card__link {
    text-decoration: none;
    color: inherit;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .product-card__image-wrap {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-background);
    position: relative;
  }
  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s;
  }
  .product-card:hover .product-card__image { transform: scale(1.05); }
  .product-card__no-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    background: var(--color-background);
  }
  .product-card__sold-out {
    position: absolute;
    width: fit-content;
    height: fit-content;
    margin: auto;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 2rem;
    padding: 0.25rem 0.75rem;
    background: rgba(0,0,0,0.65);
  }
  .product-card__flag {
    position: absolute;
    top: 6px;
    right: 6px;
    width: 24px;
    height: 16px;
    object-fit: cover;
    border-radius: 3px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.25);
  }
  .product-card__info {
    padding: 0.6rem 0.7rem 0.4rem;
    flex: 1;
  }
  .product-card__title {
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-foreground);
    margin-bottom: 0.35rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .product-card__price-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .product-card__compare {
    font-size: 0.75rem;
    color: var(--color-danger);
    text-decoration: line-through;
  }
  .product-card__price {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-price);
  }
  .product-card__actions {
    padding: 0 0.7rem 0.7rem;
  }
  .add-to-cart-btn {
    width: 100%;
    padding: 0.45rem;
    border-radius: var(--radius-sm);
    border: none;
    background: var(--color-foreground);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .add-to-cart-btn:hover { opacity: 0.85; }
  .add-to-cart-btn:disabled { background: var(--color-border); color: var(--color-muted); cursor: not-allowed; }

  /* Empty */
  .shop-empty {
    text-align: center;
    padding: 3rem 0;
    color: var(--color-muted);
    font-size: 1rem;
  }
  .shop-empty p:first-child { font-size: 3rem; margin-bottom: 0.5rem; }

  /* Pagination */
  .pagination {
    grid-column: 1 / -1;
    text-align: center;
    padding: 1.5rem 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Shop",
  "settings": []
}
{% endschema %}
