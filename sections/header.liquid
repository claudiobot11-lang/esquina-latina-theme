{% comment %} Top bar {% endcomment %}
<div class="topbar full-width">
  <div class="topbar__inner">
    <span>📍 San Bruno, CA</span>
    <div class="topbar__right">
      <a href="tel:+16505023101">📞 (650) 502-3101</a>
      <a href="https://wa.me/16506097435" target="_blank" rel="noopener noreferrer">WhatsApp</a>
    </div>
  </div>
</div>

<header class="site-header full-width">
  <div class="site-header__inner">

    <a href="{{ routes.root_url }}" class="site-header__logo">
      <div class="site-header__logo-mark">EL</div>
      <div>
        <div class="site-header__logo-name">Esquina Latina</div>
        <div class="site-header__logo-sub">Market · San Bruno</div>
      </div>
    </a>

    <nav class="site-header__nav">
      <a href="{{ routes.root_url }}" class="site-header__nav-link">Início</a>
      <a href="{{ routes.all_products_collection_url }}" class="site-header__nav-link">Loja</a>
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}" class="site-header__nav-link">{{ link.title }}</a>
      {% endfor %}
    </nav>

    <div class="site-header__actions">
      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          <button class="site-header__icon-btn">{{ 'icon-account.svg' | inline_asset_content }}</button>
        </shopify-account>
      {% endif %}
      <a href="{{ routes.cart_url }}" class="site-header__cart">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {% if cart.item_count > 0 %}
          <span class="site-header__cart-badge">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>

  </div>
</header>

{% stylesheet %}
  /* Top bar */
  .topbar {
    background: #0f0f0f;
    color: rgba(255,255,255,0.75);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .topbar__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0.45rem calc(var(--page-margin) + 0px);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .topbar__right {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }
  .topbar a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    transition: color 0.12s;
  }
  .topbar a:hover { color: #fff; }

  /* Header */
  .site-header {
    background: #ffffff;
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .site-header__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .site-header__logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .site-header__logo-mark {
    width: 36px;
    height: 36px;
    background: #0f0f0f;
    color: #fff;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }
  .site-header__logo-name {
    font-size: 0.95rem;
    font-weight: 800;
    color: #0f0f0f;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }
  .site-header__logo-sub {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-muted);
    letter-spacing: 0.02em;
    line-height: 1;
  }

  /* Nav */
  .site-header__nav {
    display: none;
    gap: 0.25rem;
    flex: 1;
  }
  @media (min-width: 768px) { .site-header__nav { display: flex; } }
  .site-header__nav-link {
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    font-weight: 500;
    color: #555;
    text-decoration: none;
    transition: all 0.12s;
  }
  .site-header__nav-link:hover {
    color: #0f0f0f;
    background: #f3f3f1;
  }

  /* Actions */
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  .site-header__icon-btn {
    background: none;
    border: none;
    padding: 0.4rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    color: #555;
    display: flex;
    align-items: center;
    transition: all 0.12s;
  }
  .site-header__icon-btn:hover { background: #f3f3f1; color: #0f0f0f; }
  .site-header__icon-btn svg { width: 1.25rem; }
  .site-header__cart {
    position: relative;
    display: flex;
    align-items: center;
    padding: 0.4rem;
    border-radius: var(--radius-sm);
    color: #555;
    text-decoration: none;
    transition: all 0.12s;
  }
  .site-header__cart:hover { background: #f3f3f1; color: #0f0f0f; }
  .site-header__cart svg { width: 1.25rem; }
  .site-header__cart-badge {
    position: absolute;
    top: 2px;
    right: 2px;
    background: #0f0f0f;
    color: #fff;
    border-radius: 50%;
    width: 16px;
    height: 16px;
    font-size: 0.6rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
